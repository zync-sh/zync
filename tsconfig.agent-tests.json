{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "noEmit": false,
    "outDir": ".tmp-agent-tests",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/components/editor/codemirror/fileTypes.ts",
    "src/components/editor/codemirror/comments.ts",
    "src/components/editor/codemirror/keymap.ts",
    "src/components/editor/codemirror/status.ts",
    "src/components/editor/codemirror/theme.ts",
    "src/components/editor/providers.ts",
    "src/components/ui/Button.tsx",
    "src/components/ui/KeyboardKey.tsx",
    "src/components/ai/sidebarSubmit.ts",
    "src/components/ai/providerCatalog.ts",
    "src/components/ai/useAiSidebarResize.ts",
    "src/ai/store/agentStore.ts",
    "src/ai/store/agentRunStore.ts",
    "src/ai/types/agent.ts",
    "src/ai/lib/requestContext.ts",
    "src/ai/lib/redactContext.ts"
  ]
}
