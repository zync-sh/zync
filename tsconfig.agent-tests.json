{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": false,
    "noEmit": false,
    "outDir": ".tmp-agent-tests",
    "rootDir": ".",
    "declaration": false,
    "sourceMap": false
  },
  "include": [
    "src/components/light-editor/search.ts",
    "src/components/light-editor/highlight.ts",
    "src/components/light-editor/interactions.ts",
    "src/components/light-editor/commands.ts",
    "src/components/light-editor/core/brackets.ts",
    "src/components/light-editor/core/lineModel.ts",
    "src/components/light-editor/core/projection.ts",
    "src/components/light-editor/occurrences.ts",
    "src/components/light-editor/diagnostics/useLightEditorDiagnostics.ts",
    "src/components/light-editor/folding/useLightEditorFolding.ts",
    "src/components/light-editor/folding/useLightEditorProjection.ts",
    "src/components/light-editor/layout.ts",
    "src/components/light-editor/useLightEditorContextMenu.ts",
    "src/components/light-editor/theme/themes.ts",
    "src/components/light-editor/LightCompletionPanel.tsx",
    "src/components/light-editor/LightEditorHeader.tsx",
    "src/components/light-editor/LightFindReplaceBar.tsx",
    "src/components/light-editor/LightGoToLineBar.tsx",
    "src/components/light-editor/LightShortcutsList.tsx",
    "src/components/light-editor/panels/EditorPanelHost.tsx",
    "src/components/light-editor/content/provider.ts",
    "src/components/light-editor/minimap/useLightEditorMinimap.ts",
    "src/components/light-editor/status.ts",
    "src/components/light-editor/useLightEditorUtilities.ts",
    "src/components/ui/Button.tsx",
    "src/components/ui/KeyboardKey.tsx",
    "src/components/ai/sidebarSubmit.ts",
    "src/components/ai/providerCatalog.ts",
    "src/components/ai/useAiSidebarResize.ts",
    "src/ai/store/agentStore.ts",
    "src/ai/store/agentRunStore.ts",
    "src/ai/types/agent.ts",
    "src/ai/lib/requestContext.ts",
    "src/ai/lib/redactContext.ts"
  ]
}
